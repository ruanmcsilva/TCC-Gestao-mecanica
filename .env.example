# Exemplo de arquivo de variáveis de ambiente para o projeto Gestão Mecânica

# Configurações do Django
DJANGO_SECRET_KEY=sua_chave_secreta_super_segura_aqui
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=seusite.com.br,127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=https://seusite.com.br,http://localhost:5173
CSRF_TRUSTED_ORIGINS=https://seusite.com.br,http://localhost:8000

# Configurações do Banco de Dados PostgreSQL
POSTGRES_DB=gestao_mecanica
POSTGRES_USER=usuario_banco
POSTGRES_PASSWORD=senha_banco_super_segura
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Configurações de E-mail
EMAIL_HOST_USER=seu_email@gmail.com
EMAIL_HOST_PASSWORD=sua_senha_de_aplicativo_aqui

# APIs Externas
GEMINI_API_KEY=sua_api_key_do_gemini
GEMINI_MODEL=gemini-2.5-flash
FOCUSNFE_TOKEN=seu_token_focusnfe_aqui
